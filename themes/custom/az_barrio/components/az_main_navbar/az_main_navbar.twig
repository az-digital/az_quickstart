{% macro menu_links(items, menu_id, menu_level, parent_item) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul class="navbar-nav"{% if menu_id %} id="{{ menu_id }}"{% endif %}>
    {% elseif menu_level == 1 %}
      <ul class="dropdown-menu" id="secondary-{{ parent_item.title|clean_class }}">
    {% elseif menu_level == 2 %}
      <ul class="collapse{% if parent_item.in_active_trail %} show{% endif %}" id="tertiary-{{ parent_item.title|clean_class }}"{% if menu_id %} data-bs-parent="#{{ menu_id }}"{% endif %}>
    {% endif %}
    {% for item in items %}
      {% set is_placeholder = (
        item.url.toString() is empty or item.url.toString() == '#'
      ) or (
        item.url.isRouted() and item.url.getRouteName() in ['<nolink>', '<none>']
      ) %}
      {% set item_classes = [
        menu_level == 0 ? 'nav-item',
        item.in_active_trail ? 'active',
        item.below ? 'dropdown',
        (menu_level == 0 and item.below and not is_placeholder) ? 'btn-group'
      ] %}

      <li{{ item.attributes.addClass(item_classes) }}>
        {% if menu_level == 0 %}
          {% if item.below and is_placeholder %}
            <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">{{ item.title }}</a>
          {% else %}
            {{ link(item.title, item.url, { 'class': 'nav-link' }) }}
          {% endif %}
          {% if item.below %}
            {% if not is_placeholder %}
              <button type="button" class="btn dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                <span class="visually-hidden">{{ item.title }}</span>
              </button>
            {% endif %}
            {{ menus.menu_links(item.below, menu_id, menu_level + 1, item) }}
          {% endif %}
        {% elseif menu_level == 1 %}
          {% if item.below %}
            <div class="btn-group">
              {{ link(item.title, item.url, { 'class': 'dropdown-item' }) }}
              <button type="button" class="btn dropdown-toggle dropdown-toggle-split" data-bs-toggle="collapse" data-bs-target="#tertiary-{{ item.title|clean_class }}" data-bs-auto-close="outside" aria-controls="tertiary-{{ item.title|clean_class }}" aria-expanded="{{ item.in_active_trail ? 'true' : 'false' }}">
                <span class="visually-hidden">{{ item.title }}</span>
              </button>
            </div>
            {{ menus.menu_links(item.below, menu_id, menu_level + 1, item) }}
          {% else %}
            {{ link(item.title, item.url, { 'class': 'dropdown-item' }) }}
          {% endif %}
        {% else %}
          {{ link(item.title, item.url) }}
        {% endif %}
      </li>
      {% if menu_level == 0 and not loop.last %}
        <li class="nav-item" role="presentation"><span class="vr" aria-hidden="true"></span></li>
      {% endif %}
    {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}
